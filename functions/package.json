{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "serve:emulator": "firebase emulators:start --only functions",
    "serve": "npm run serve:emulator",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "test:unit": "node --test *.test.js",
    "test": "npm run test:unit",
    "deploy:codebase": "firebase deploy --only functions",
    "deploy": "npm run deploy:codebase",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "date-fns": "^2.30.0",
    "firebase-admin": "^12.1.1",
    "firebase-functions": "^5.0.1",
    "nodemailer": "^7.0.12"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
