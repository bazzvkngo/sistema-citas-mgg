# Frontend (Vite)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_APPCHECK_SITE_KEY=""
# URL publica completa. Incluye subruta si aplica, por ejemplo:
# https://tu-dominio.com/sistema-citas
VITE_PUBLIC_APP_URL=""

# Solo desarrollo/local. En hosting publico debe quedar vacio.
# Usa true o un debug token real solo en localhost.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=""

# Cloud Functions secrets are not stored in this file.
# Configure them with `firebase functions:secrets:set`.
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
# APP_PUBLIC_URL=
